

generator client {
  provider = "prisma-client-js"
  output   = "../../apps/web/src/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ability {
  id              String   @id @default(uuid())
  ability_id      String   @unique @db.VarChar(191)
  ability_name    String
  description     String @db.LongText
  tactic          String
  technique_id    String
  technique_name  String
  platform        String
  shell_type      String
  command         String @db.MediumText
  payload         String @db.LongText
  type            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum FuzzingJobStatus {
  DRAFT
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum FuzzingTargetType {
  ISO15118
  OCPP_CHARGER
  OCPP_SERVER
}

enum FuzzingTargetDevice {
  CHARGER
  CSMS
}

model FuzzingJob {
  id                String            @id @default(uuid())
  name              String
  targetType        FuzzingTargetType
  targetDevice      FuzzingTargetDevice?
  environment       String
  connectionConfig  Json              // Stores target-specific connection details
  fuzzingParameters Json              // Stores fuzzing configuration parameters
  scope             Json?             // Stores list of selected messages/scopes
  status            FuzzingJobStatus   @default(DRAFT)
  authTokenHash     String            // Hashed token for secure report submission
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  report            FuzzingReport?

  @@index([status])
  @@index([targetType])
  @@index([createdAt])
}

model FuzzingReport {
  id        String      @id @default(uuid())
  jobId     String      @unique
  job       FuzzingJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  payload   Json        // Stores the full FuzzingReport JSON structure
  createdAt DateTime    @default(now())

  @@index([jobId])
}
 